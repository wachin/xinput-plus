# -----------------------------
# Python / environment
# -----------------------------
__pycache__/
*.py[cod]
*$py.class
.env
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/

# -----------------------------
# Qt / PyQt / Qt Creator
# -----------------------------
# Compiled translations (generated at build time)
i18n/*.qm
# Qt Creator / qmake temporary files
*.pro.user
*.qbs.user
*.qbs.user.*
*.qmlproject.user
*.qmlproject.user.*
*.qtcreator
*.qtcreator.*
.qmake.stash

# -----------------------------
# Python build artefacts
# -----------------------------
build/
dist/
*.egg-info/

# -----------------------------
# Debian packaging artefacts
# -----------------------------
# Ignore everything generated inside debian/ during a build:
debian/.debhelper/
debian/*-stamp
debian/debhelper-build-stamp
debian/tmp/
debian/files
debian/*.log
debian/*.substvars
debian/*/
# ...but keep the packaging source files:
!debian/changelog
!debian/control
!debian/rules
!debian/copyright
!debian/source/
!debian/source/format
!debian/watch
!debian/xinput-plus.desktop
!debian/xinput-plus.metainfo.xml
!debian/xinput-plus.1

# -----------------------------
# uscan / orig tarballs / debuild
# (sometimes left in the tree by mistake)
# -----------------------------
*.orig.tar.*
*.debian.tar.*
*.dsc
*.build
*.buildinfo
*.changes
# Tarball renamed by uscan in the working tree
xinput-plus-*.tar.gz

# -----------------------------
# OS / editor files
# -----------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# -----------------------------
# README assets (do NOT ignore assets/; commit them)
# -----------------------------
# (intentionally empty)
